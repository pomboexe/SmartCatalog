PORT=3333
JWT_SECRET=troque-isso-por-um-segredo-forte
JWT_EXPIRES_IN=7d
GROQ_API_KEY=sua_chave_groq_aqui
GROQ_MODEL=llama-3.3-70b-versatile

# URL usada pelo browser para chamar a API (não use o hostname do container)
VITE_API_URL=http://localhost:3333

# Dev:  npm run docker:dev     → http://localhost:5173  |  npm run docker:dev:down
# Prod: npm run docker:prod    → http://localhost:8080  |  npm run docker:prod:down
# API (ambos): http://localhost:3333
